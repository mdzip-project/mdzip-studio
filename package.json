{
  "name": "mdzip-studio",
  "version": "1.3.18",
  "description": "Reference desktop application for the MDZip ecosystem with CommonMark/GFM Markdown support",
  "author": "MDZip Project",
  "license": "Apache-2.0",
  "main": "electron/main.js",
  "homepage": "./",
  "scripts": {
    "prestart": "node scripts/generate-about-data.js",
    "start": "concurrently \"npm run start:angular\" \"wait-on http://localhost:4300 && npm run start:electron\"",
    "start:angular": "ng serve --port 4300",
    "start:electron": "electron .",
    "prebuild": "node scripts/bump-version.js && node scripts/generate-about-data.js && npm run build:preview-handler",
    "build": "npm run build:angular && npm run build:electron",
    "build:angular": "ng build --configuration production",
    "build:electron": "electron-builder",
    "build:preview-handler": "node scripts/publish-preview-handler.cjs",
    "install:electron": "node node_modules/electron/install.js",
    "test": "ng test",
    "lint": "ng lint"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "build": {
    "appId": "org.mdzip.studio",
    "productName": "MDZip Studio",
    "artifactName": "MDZip-Studio-Setup-${version}.${ext}",
    "publish": [
      {
        "provider": "github",
        "owner": "mdzip-project",
        "repo": "mdzip-studio"
      }
    ],
    "files": [
      "dist/mdzip-studio/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/preview-handler",
        "to": "preview-handler"
      },
      {
        "from": "build/file-icons",
        "to": "file-icons"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon.ico",
      "signExts": [
        "mdz.WinPrev.comhost.dll",
        "mdz.WinPrev.dll",
        "mdzip.core.dll",
        "Markdig.dll"
      ]
    },
    "nsis": {
      "include": "build/installer.nsh",
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "deleteAppDataOnUninstall": false
    }
  },
  "devDependencies": {
    "@angular/animations": "21.2.14",
    "@angular/build": "^21.2.14",
    "@angular/cdk": "21.2.14",
    "@angular/cli": "21.2.14",
    "@angular/common": "21.2.14",
    "@angular/compiler": "21.2.14",
    "@angular/compiler-cli": "21.2.14",
    "@angular/core": "21.2.14",
    "@angular/forms": "21.2.14",
    "@angular/platform-browser": "21.2.14",
    "@angular/platform-browser-dynamic": "21.2.14",
    "@angular/router": "21.2.14",
    "@mdzip/core-js": "1.3.1",
    "@mdzip/editor": "file:../mdzip-editor/local-packages/1.3.11/mdzip-editor-1.3.11.tgz",
    "@mdzip/editor-ng": "file:../mdzip-editor/local-packages/1.3.11/mdzip-editor-ng-1.3.11.tgz",
    "@ng-icons/core": "^33.2.3",
    "@ng-icons/lucide": "^33.2.3",
    "@primeng/themes": "21.0.4",
    "@primeuix/themes": "^2.0.3",
    "@types/node": "^20.0.0",
    "concurrently": "^8.0.0",
    "electron": "^42.3.3",
    "electron-builder": "^26.8.1",
    "jsdom": "^29.1.1",
    "mermaid": "^11.15.0",
    "primeicons": "^7.0.0",
    "primeng": "21.1.9",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1",
    "typescript": "~5.9.3",
    "vitest": "^4.1.8",
    "wait-on": "^9.0.10",
    "zone.js": "~0.16.0"
  }
}
